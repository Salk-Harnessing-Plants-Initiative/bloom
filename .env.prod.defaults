# =============================================================================
# Bloom v2 — production deploy-time env config (non-sensitive)
#
# This file is COMMITTED. It contains configuration values only:
# domains, ports, URLs, feature flags, standard identifiers. Nothing
# sensitive — no passwords, no API keys, no cryptographic material.
#
# At deploy time the workflow:
#   1. Copies this file to $PROD_DEPLOY_PATH/.env.prod
#   2. Appends sensitive values from GitHub Secrets (cat >> .env.prod)
#   3. Validates the assembled file has every required key
#   4. Starts `docker compose up`
#
# Sensitive values live in GitHub Secrets under these names:
#   PROD_POSTGRES_PASSWORD, PROD_JWT_SECRET, PROD_ANON_KEY,
#   PROD_SERVICE_ROLE_KEY, PROD_DB_ENC_KEY, PROD_MINIO_PASSWORD,
#   PROD_VAULT_ENC_KEY, PROD_SUPAVISOR_ENC_KEY, PROD_SECRET_KEY_BASE,
#   PROD_DASHBOARD_PASSWORD, PROD_BLOOMMCP_API_KEY, PROD_OPENAI_API_KEY,
#   PROD_LANGCHAIN_API_KEY, PROD_BLOOM_AGENT_KEY
#
# CI enforces that nothing in this file matches PASSWORD|SECRET|KEY|TOKEN.
# See openspec/changes/refactor-env-config-committed-defaults/ for rationale.
# =============================================================================

# Domains
DOMAIN_MAIN=bloom-dev.salk.edu
DOMAIN_STUDIO=studio.bloom-dev.salk.edu
DOMAIN_MINIO=minio.bloom-dev.salk.edu

# Caddy
CADDY_HTTP_LISTEN_PORT=80
CADDY_HTTPS_LISTEN_PORT=443
CADDY_HTTP_PORT=
CADDY_TLS_DIRECTIVE=tls internal

# Database
POSTGRES_DB=postgres
POSTGRES_USER=supabase_admin
POSTGRES_PORT=5432
POSTGRES_HOST=db-prod
POSTGRES_HOST_PORT=5432
PGRST_DB_SCHEMAS=public,auth,storage

# Service ports (Docker internal)
KONG_PORT=8000
BLOOM_WEB_PORT=3000
STUDIO_PORT=3000
MINIO_CONSOLE_PORT=9001

# Supavisor pooler
POOLER_TENANT_ID=default
POOLER_DEFAULT_POOL_SIZE=5
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=10

# Studio organization / project labels (display-only, not auth)
STUDIO_DEFAULT_ORGANIZATION=Bloom
STUDIO_DEFAULT_PROJECT=default
# DASHBOARD_USERNAME and MINIO_ROOT_USER live in GitHub Secrets — they pair
# with admin passwords, so treat as credentials rather than config.

# URLs
SITE_URL=https://bloom-dev.salk.edu
API_EXTERNAL_URL=https://bloom-dev.salk.edu/api
ADDITIONAL_REDIRECT_URLS=https://bloom-dev.salk.edu
NEXT_PUBLIC_SUPABASE_URL=https://bloom-dev.salk.edu/api
NEXT_PUBLIC_APP_URL=https://bloom-dev.salk.edu
SUPABASE_URL=http://kong:8000
SUPABASE_PUBLIC_URL=https://bloom-dev.salk.edu/api
SUPABASE_COOKIE_NAME=sb-bloom-auth-token
STUDIO_SUPABASE_PUBLIC_URL=https://studio.bloom-dev.salk.edu
MINIO_BROWSER_REDIRECT_URL=https://minio.bloom-dev.salk.edu
CORS_ORIGINS=https://bloom-dev.salk.edu
BLOOM_PLOTS_URL=https://bloom-dev.salk.edu/plots

# Internal service URLs
BLOOM_MCP_URL=http://bloommcp:8811/mcp
IMGPROXY_URL=http://imgproxy:5001
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Bloom app paths
BLOOM_PLOTS_DIR=/app/data/PLOTS_DIR

# Auth flags
ENABLE_ANONYMOUS_USERS=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
DISABLE_SIGNUP=false
JWT_EXPIRY=3600

# LangChain / LangSmith
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=bloom-prod

# Local LLM (vLLM). LOCAL_LLM_MODEL takes precedence — when set to a static
# name, agent.py short-circuits the URL probe entirely. URL is a placeholder
# so the validator accepts the value; replace with real vLLM endpoint when
# enabling local-LLM deploys.
LOCAL_LLM_URL=http://disabled
LOCAL_LLM_MODEL=skip
