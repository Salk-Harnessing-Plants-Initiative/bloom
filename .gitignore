# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/web/test-results
/web/playwright-report
/web/blob-report

# next.js
/.next/
/out/

# production
/build
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (root and all subdirectories)
.env*
.env
**/.env
**/.env.*
.env.prod
# Rollback snapshots written by the deploy workflow (contain prior secrets)
.env.prod.previous
.env.staging.previous
**/.env.prod.previous
**/.env.staging.previous
# Committed deploy-time config defaults (NOT secrets — see the files themselves)
!.env.prod.defaults
!.env.staging.defaults
!**/.env.prod.defaults
!**/.env.staging.defaults

# generated secret dumps from scripts/generate-secrets.sh --file
.secrets-*.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

