# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/web/test-results
/web/playwright-report
/web/blob-report

# next.js
/.next/
/out/

# production
/build
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (root and all subdirectories)
.env*
.env
**/.env
**/.env.*
.env.prod
# Rollback snapshots written by the deploy workflow (contain prior secrets)
.env.prod.previous
.env.staging.previous
**/.env.prod.previous
**/.env.staging.previous
# Committed deploy-time config defaults (NOT secrets — see the files themselves)
!.env.prod.defaults
!.env.staging.defaults
!**/.env.prod.defaults
!**/.env.staging.defaults

# generated secret dumps from scripts/generate-secrets.sh --file
.secrets-*.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc
*.pyo

.venv
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# project-specific
/extra
volumes/
!volumes/db/
!volumes/db/*.sql
!volumes/db/*.sh
!volumes/db/init/
!volumes/db/init/*
volumes/db/data/
!volumes/api/
!volumes/api/kong.yml
!volumes/pooler/
!volumes/pooler/pooler.exs

# minio
minio/data/
minio_data/

# temporary/copy files
nginx/copy.config
nginx/copy.config_2
docker-compose.prod copy.yml
DOCUMENTATION.md
TROUBLESHOOTING.md
prompts/
# Re-include the langchain agent's prompt module (the gitignore rule above
# catches Claude-Code planning folders named `prompts/`; this re-includes
# the production code path the agent uses for graph-node prompts).
!langchain/prompts/
!langchain/prompts/**
.claude/settings.local.json
.claude/draft-pr/
langchain/ANALYSIS_OUTPUT/
langchain/PLOTS_DIR/
scripts/compute_de_genes.py
scripts/compute_de_local.py
scripts/compute_de.py
scripts/generate_KEYS
scripts/dev/
*.bak

prompts/.claude/

# setup/deployment notes (local only)
.setup/

# local-only design references (prototypes, handoff docs)
reference/

# supabase CLI session cache
supabase/.temp/

# Stray uv lockfiles outside the three known service dirs.
# The tracked service uv.locks (langchain/, bloommcp/, services/video-worker/)
# are unaffected because gitignore doesn't apply to already-tracked files —
# `scripts/check-uv-locks.py` enforces those. This rule keeps a one-off
# `uv.lock` (e.g. from running `uv` at the repo root for the test extra,
# or in a new subdir) from polluting `git status`.
uv.lock

# agents scratch (claude skill system)
.agents/
skills-lock.json
