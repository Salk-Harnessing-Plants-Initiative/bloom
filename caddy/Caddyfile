# =============================================================================
# Bloom v2 Caddyfile
#
# Routes:
#   {DOMAIN_MAIN}        → bloom-web (frontend)
#   {DOMAIN_MAIN}/api/*  → kong (Supabase API gateway, /api prefix stripped)
#   {DOMAIN_STUDIO}      → studio (Supabase Studio)
#   {DOMAIN_MINIO}       → minio console
#
# TLS:
#   `tls internal` → Caddy generates its own CA and server certs locally.
#   Browsers show a one-time "not secure" warning because the CA isn't
#   publicly trusted. Encryption itself is real. Acceptable short-term
#   for a Salk-network-only service where public ACME (Let's Encrypt
#   HTTP-01) can't reach us.
#
# When Salk IT provides a real cert, swap `tls internal` for either:
#   tls /etc/caddy/certs/<domain>.crt /etc/caddy/certs/<domain>.key
# or (with DNS-01 ACME):
#   tls { dns <provider> {env.<TOKEN>} }
# One line per site block; no other Caddyfile changes needed.
# =============================================================================

# -------------------
# Main Application
# -------------------
{$DOMAIN_MAIN} {
	tls internal

	# Supabase API — strip /api prefix, proxy to Kong
	handle_path /api/* {
		reverse_proxy kong:{$KONG_PORT}
	}

	# Bloom Frontend
	handle {
		reverse_proxy bloom-web:{$BLOOM_WEB_PORT}
	}
}

# -------------------
# Supabase Studio
# -------------------
{$DOMAIN_STUDIO} {
	tls internal

	# Studio backend routes → Kong
	handle_path /auth/* {
		reverse_proxy kong:{$KONG_PORT} {
			rewrite /auth{uri}
		}
	}

	handle_path /rest/* {
		reverse_proxy kong:{$KONG_PORT} {
			rewrite /rest{uri}
		}
	}

	handle_path /storage/* {
		reverse_proxy kong:{$KONG_PORT} {
			rewrite /storage{uri}
		}
	}

	handle_path /realtime/* {
		reverse_proxy kong:{$KONG_PORT} {
			rewrite /realtime{uri}
		}
	}

	# Studio UI
	handle {
		reverse_proxy studio:{$STUDIO_PORT}
	}
}

# -------------------
# MinIO Console
# -------------------
{$DOMAIN_MINIO} {
	tls internal

	reverse_proxy supabase-minio:{$MINIO_CONSOLE_PORT} {
		transport http {
			read_timeout 300s
			write_timeout 300s
		}
	}
}
