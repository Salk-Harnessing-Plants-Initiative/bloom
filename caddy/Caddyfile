# =============================================================================
# Bloom v2 Caddyfile
#
# Routes (all served by ONE wildcard SAN cert — see below):
#   {DOMAIN_MAIN}              → bloom-web (frontend)
#   {DOMAIN_MAIN}/api/client-info → bloom-web (public {api_url, anon_key} for
#                              CLI bootstrap — exact path, ahead of /api/*)
#   {DOMAIN_MAIN}/api/*        → kong (Supabase API gateway, /api prefix stripped)
#   {DOMAIN_MAIN}/langchain/*  → langchain-agent (FastAPI, prefix preserved)
#   {DOMAIN_MAIN}/bloommcp/*   → bloommcp (MCP server, /bloommcp prefix stripped)
#   {DOMAIN_STUDIO}            → studio (Supabase Studio)
#   {DOMAIN_MINIO}             → minio console
#
# TLS strategy:
#
#   All hostnames served by this stack are consolidated into ONE site block
#   whose listen addresses are driven by the CADDY_SITE_ADDRESSES env var.
#   Each comma-separated entry is fully formed with an explicit scheme so
#   Caddy parses it independently — this avoids the "comma + port-suffix"
#   pitfall where `host_a, host_b:port` would attach :port only to host_b
#   and leave host_a defaulting to :443 with automatic HTTPS.
#
#     prod:    `https://bloom.salk.edu, https://*.bloom.salk.edu`
#              (2-SAN cert: apex + wildcard)
#     staging: `https://*.bloom.salk.edu`
#              (1 wildcard covering all staging subdomains)
#     CI:      `http://localhost`
#              (forces HTTP-only — no TLS, no ACME, no Let's Encrypt call)
#
#   Prod and staging both issue their certs via the Salk-DNS CNAME:
#     _acme-challenge.bloom.salk.edu -> _acme-challenge.bloom-acme.talmolab.org
#   Wildcard challenges land at the parent name per the ACME spec, so a
#   single CNAME at bloom.salk.edu covers both the apex and the wildcard.
#
#   Per-hostname routing is done inside the block via `@matcher host X` +
#   `handle @matcher`, preserving the previous per-host route logic.
#
# Env vars:
#
#   CADDY_SITE_ADDRESSES  comma-separated, scheme-prefixed (http:// or
#                         https://) site addresses. The tls block below only
#                         takes effect for https:// addresses.
#
#   CLOUDFLARE_API_TOKEN  consumed by the cloudflare DNS provider plugin
#                         (caddy-dns/cloudflare) baked into the Caddy image
#                         via caddy/Dockerfile. The token requires the
#                         `Zone:DNS:Edit` permission on the Cloudflare zone
#                         containing `bloom-acme.talmolab.org`. Populated at
#                         deploy time from PROD_/STAGING_CLOUDFLARE_API_TOKEN
#                         secrets.
# =============================================================================

{$CADDY_SITE_ADDRESSES} {
	# Multi-SAN cert covering all the subjects listed in CADDY_SITE_ADDRESSES,
	# issued via ACME DNS-01 against Cloudflare's API. Prod's cert carries
	# 2 SANs (bloom.salk.edu + *.bloom.salk.edu); staging's carries 1
	# (*.bloom.salk.edu).
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
		dns_challenge_override_domain _acme-challenge.bloom-acme.talmolab.org
	}

	# -------------------
	# Main Application — DOMAIN_MAIN
	# -------------------
	@main host {$DOMAIN_MAIN}
	handle @main {
		# CLI bootstrap config: the public {api_url, anon_key}. EXACT path only
		# (no wildcard) so every other /api/* still routes to Kong unchanged.
		# Served by bloom-web's Next.js route; must NOT fall through to Kong's
		# basic-auth dashboard catch-all, which 401s it (issue #347).
		handle /api/client-info {
			reverse_proxy bloom-web:{$BLOOM_WEB_PORT}
		}

		# Supabase API — strip /api prefix, proxy to Kong
		handle_path /api/* {
			reverse_proxy kong:{$KONG_PORT}
		}

		# LangChain agent — preserve /langchain prefix (FastAPI routes are
		# defined as /langchain/chat, /langchain/chat/stream, etc).
		# flush_interval -1 forwards SSE chunks immediately without buffering.
		handle /langchain/* {
			reverse_proxy langchain-agent:5002 {
				flush_interval -1
			}
		}

		# Bloommcp MCP server — strip /bloommcp prefix, proxy to FastMCP on 8811.
		# Auth is enforced by bloommcp itself (Bearer token via BLOOMMCP_API_KEY)
		# so Caddy doesn't need to do auth here. Salk-network-internal only.
		handle_path /bloommcp/* {
			reverse_proxy bloommcp:8811 {
				flush_interval -1
			}
		}

		# Workflows API — strip /workflows prefix, proxy to FastAPI on 5100.
		# App routes are unprefixed (/health, /), so .../workflows/health → /health.
		handle_path /workflows/* {
			reverse_proxy workflows:5100
		}

		# Bloom Frontend
		handle {
			reverse_proxy bloom-web:{$BLOOM_WEB_PORT}
		}
	}

	# -------------------
	# Supabase Studio — DOMAIN_STUDIO
	# -------------------
	@studio host {$DOMAIN_STUDIO}
	handle @studio {
		# Studio backend routes → Kong
		handle_path /auth/* {
			reverse_proxy kong:{$KONG_PORT} {
				rewrite /auth{uri}
			}
		}

		handle_path /rest/* {
			reverse_proxy kong:{$KONG_PORT} {
				rewrite /rest{uri}
			}
		}

		handle_path /storage/* {
			reverse_proxy kong:{$KONG_PORT} {
				rewrite /storage{uri}
			}
		}

		handle_path /realtime/* {
			reverse_proxy kong:{$KONG_PORT} {
				rewrite /realtime{uri}
			}
		}

		# Studio UI
		handle {
			reverse_proxy studio:{$STUDIO_PORT}
		}
	}

	# -------------------
	# MinIO Console — DOMAIN_MINIO
	# -------------------
	@minio host {$DOMAIN_MINIO}
	handle @minio {
		reverse_proxy supabase-minio:{$MINIO_CONSOLE_PORT} {
			transport http {
				read_timeout 300s
				write_timeout 300s
			}
		}
	}
}

# -------------------
# Internal Health Endpoint
# -------------------
# Used by Docker healthcheck only. Not exposed externally (port 2021 is
# not published in docker-compose). Bind to :2021 on a fresh listener
# so it doesn't collide with the public 80/443 block above.
:2021 {
	respond /caddy-health "ok" 200
}
