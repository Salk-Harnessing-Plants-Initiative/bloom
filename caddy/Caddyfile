# =============================================================================
# Bloom v2 Caddyfile
#
# Routes:
#   {DOMAIN_MAIN}        → bloom-web (frontend)
#   {DOMAIN_MAIN}/api/*  → kong (Supabase API gateway, /api prefix stripped)
#   {DOMAIN_STUDIO}      → studio (Supabase Studio)
#   {DOMAIN_MINIO}       → minio console
#
# TLS is controlled by two env vars:
#
#   CADDY_HTTP_PORT       site-header suffix on the listen address
#     prod/staging:       empty   → Caddy auto-binds 80 + 443
#     CI / local HTTP:    `:80`   → Caddy binds only 80, no TLS
#
#   CADDY_TLS_DIRECTIVE   first directive inside each site block
#     prod/staging:       `tls internal` (Caddy signs certs with its
#                         local CA — works on a Salk-network-only host
#                         where Let's Encrypt HTTP-01 can't reach us)
#     CI:                 empty   → plain HTTP, no cert generation
#
# When Salk IT provides a real cert, set CADDY_TLS_DIRECTIVE in .env.prod
# to one of:
#   `tls /etc/caddy/certs/<domain>.crt /etc/caddy/certs/<domain>.key`
# or (ACME DNS-01):
#   `tls { dns <provider> {env.<TOKEN>} }`
# =============================================================================

# -------------------
# Main Application
# -------------------
{$DOMAIN_MAIN}{$CADDY_HTTP_PORT} {
	{$CADDY_TLS_DIRECTIVE}

	# Supabase API — strip /api prefix, proxy to Kong
	handle_path /api/* {
		reverse_proxy kong:{$KONG_PORT}
	}

	# Bloom Frontend
	handle {
		reverse_proxy bloom-web:{$BLOOM_WEB_PORT}
	}
}

# -------------------
# Supabase Studio
# -------------------
{$DOMAIN_STUDIO}{$CADDY_HTTP_PORT} {
	{$CADDY_TLS_DIRECTIVE}

	# Studio backend routes → Kong
	handle_path /auth/* {
		reverse_proxy kong:{$KONG_PORT} {
			rewrite /auth{uri}
		}
	}

	handle_path /rest/* {
		reverse_proxy kong:{$KONG_PORT} {
			rewrite /rest{uri}
		}
	}

	handle_path /storage/* {
		reverse_proxy kong:{$KONG_PORT} {
			rewrite /storage{uri}
		}
	}

	handle_path /realtime/* {
		reverse_proxy kong:{$KONG_PORT} {
			rewrite /realtime{uri}
		}
	}

	# Studio UI
	handle {
		reverse_proxy studio:{$STUDIO_PORT}
	}
}

# -------------------
# MinIO Console
# -------------------
{$DOMAIN_MINIO}{$CADDY_HTTP_PORT} {
	{$CADDY_TLS_DIRECTIVE}

	reverse_proxy supabase-minio:{$MINIO_CONSOLE_PORT} {
		transport http {
			read_timeout 300s
			write_timeout 300s
		}
	}
}

# -------------------
# Internal Health Endpoint
# -------------------
# Used by Docker healthcheck only. Not exposed externally (port 2021 is
# not published in docker-compose). Bind to :2021 on a fresh listener
# so it doesn't collide with the public 80/443 blocks above.
:2021 {
	respond /caddy-health "ok" 200
}
