# =============================================================================
# Bloom v2 — staging deploy-time env config (non-sensitive)
#
# Staging runs on the same host as prod, using a different compose project
# (bloom_v2_staging via `-p` flag). Ports are offset to avoid collision:
#   Caddy HTTP   :8080  (vs prod :80)
#   Caddy HTTPS  :8443  (vs prod :443)
#   Postgres     :5433  (vs prod :5432)
#
# POSTGRES_HOST=db-prod is intentional — both environments use the SAME
# docker-compose.prod.yml; the service name is `db-prod` for both. Compose
# projects keep the containers isolated via the `-p bloom_v2_staging` flag.
#
# See .env.prod.defaults for the assembly + lint model.
# =============================================================================

# Domains
DOMAIN_MAIN=staging-bloom-dev.salk.edu
DOMAIN_STUDIO=staging-studio.bloom-dev.salk.edu
DOMAIN_MINIO=staging-minio.bloom-dev.salk.edu

# Caddy (non-standard ports so prod and staging coexist on the same host)
CADDY_HTTP_LISTEN_PORT=8080
CADDY_HTTPS_LISTEN_PORT=8443
CADDY_HTTP_PORT=
CADDY_TLS_DIRECTIVE=tls internal

# Database
POSTGRES_DB=postgres
POSTGRES_USER=supabase_admin
POSTGRES_PORT=5432
POSTGRES_HOST=db-prod
POSTGRES_HOST_PORT=5433
PGRST_DB_SCHEMAS=public,auth,storage

# Service ports (Docker internal)
KONG_PORT=8000
BLOOM_WEB_PORT=3000
STUDIO_PORT=3000
MINIO_CONSOLE_PORT=9001

# Supavisor pooler
POOLER_TENANT_ID=default
POOLER_DEFAULT_POOL_SIZE=5
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=10

# Studio organization / project labels (display-only, not auth)
STUDIO_DEFAULT_ORGANIZATION=Bloom
STUDIO_DEFAULT_PROJECT=default
# DASHBOARD_USERNAME and MINIO_ROOT_USER live in GitHub Secrets — they pair
# with admin passwords, so treat as credentials rather than config.

# URLs (non-standard 8443 port must appear in every user-facing URL)
SITE_URL=https://staging-bloom-dev.salk.edu:8443
API_EXTERNAL_URL=https://staging-bloom-dev.salk.edu:8443/api
ADDITIONAL_REDIRECT_URLS=https://staging-bloom-dev.salk.edu:8443
NEXT_PUBLIC_SUPABASE_URL=https://staging-bloom-dev.salk.edu:8443/api
NEXT_PUBLIC_APP_URL=https://staging-bloom-dev.salk.edu:8443
SUPABASE_URL=http://kong:8000
SUPABASE_PUBLIC_URL=https://staging-bloom-dev.salk.edu:8443/api
SUPABASE_COOKIE_NAME=sb-bloom-auth-token
STUDIO_SUPABASE_PUBLIC_URL=https://staging-studio.bloom-dev.salk.edu:8443
MINIO_BROWSER_REDIRECT_URL=https://staging-minio.bloom-dev.salk.edu:8443
CORS_ORIGINS=https://staging-bloom-dev.salk.edu:8443
BLOOM_PLOTS_URL=https://staging-bloom-dev.salk.edu:8443/plots

# Internal service URLs
BLOOM_MCP_URL=http://bloommcp:8811/mcp
IMGPROXY_URL=http://imgproxy:5001
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Bloom app paths
BLOOM_PLOTS_DIR=/app/data/PLOTS_DIR

# Auth flags
ENABLE_ANONYMOUS_USERS=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
DISABLE_SIGNUP=false
JWT_EXPIRY=3600

# LangChain / LangSmith
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=bloom-staging

# Local LLM (vLLM). LOCAL_LLM_MODEL takes precedence — when set to a static
# name, agent.py short-circuits the URL probe entirely. URL is a placeholder
# so the validator accepts the value; replace with real vLLM endpoint when
# enabling local-LLM deploys.
LOCAL_LLM_URL=http://disabled
LOCAL_LLM_MODEL=skip
