# Local development environment template for the Bloom Supabase stack.
#
# Usage:
#   make init          # copies this to .env.dev and fills every CHANGEME value
#                      # with a freshly generated local secret (see scripts/init_dev.py)
#   make dev-up        # start the stack
#
# Values marked CHANGEME are generated by `make init`. Values left blank are
# optional and user-supplied (e.g. third-party API keys). Everything else is
# safe, non-secret local config. NEVER commit the generated .env.dev.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=postgres
POSTGRES_USER=supabase_admin
POSTGRES_PASSWORD=CHANGEME
POSTGRES_PORT=5432
POSTGRES_HOST=db-dev
# Host-exposed port. Override to 5433 if host 5432 is already taken
# (e.g. a WSL-relayed Postgres from another project).
POSTGRES_HOST_PORT=5432

# PostgREST — which schemas to expose over REST
PGRST_DB_SCHEMAS=public,auth,storage

# ── JWT / API keys (generated; ANON/SERVICE/AGENT are JWTs signed by JWT_SECRET) ─
JWT_SECRET=CHANGEME
JWT_EXPIRY=3600
ANON_KEY=CHANGEME
SERVICE_ROLE_KEY=CHANGEME
# bloom_agent-role JWT used by bloommcp + langchain-agent
BLOOM_AGENT_KEY=CHANGEME

# ── Encryption keys (generated; sizes enforced by scripts/init_dev.py) ───────
# DB_ENC_KEY MUST be exactly 16 bytes (Realtime AES-128); VAULT_ENC_KEY 32;
# SECRET_KEY_BASE >=64; SUPAVISOR_ENC_KEY 64 hex.
SUPAVISOR_ENC_KEY=CHANGEME
VAULT_ENC_KEY=CHANGEME
SECRET_KEY_BASE=CHANGEME
DB_ENC_KEY=CHANGEME

# ── MinIO (S3 storage backend) ───────────────────────────────────────────────
MINIO_ROOT_USER=bloom-dev
MINIO_ROOT_PASSWORD=CHANGEME
MINIO_DEFAULT_BUCKET=bloom-storage
MINIO_STORAGE_S3_ENDPOINT=http://supabase-minio:9000
MINIO_S3_STORAGE_REGION=us-east-1
MINIO_DATA_PATH=./volumes/minio-dev
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# ── Kong API gateway ─────────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
KONG_PORT=8000

# ── Application URLs ─────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:9999
ADDITIONAL_REDIRECT_URLS=http://localhost:3000
SUPABASE_URL=http://kong:8000
SUPABASE_PUBLIC_URL=http://localhost:8000
SUPABASE_COOKIE_NAME=sb-localhost-auth-token
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGEME
NEXT_PUBLIC_APP_URL=http://localhost:3000
FLASK_SUPABASE_URL=http://kong:8000/
CORS_ORIGINS=http://localhost:3000,http://localhost

# ── Connection pooler (Supavisor) ────────────────────────────────────────────
POOLER_TENANT_ID=default
POOLER_DEFAULT_POOL_SIZE=5
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=10
POOLER_PROXY_PORT_TRANSACTION=6543

# ── Supabase dashboard / Studio ──────────────────────────────────────────────
DASHBOARD_USERNAME=bloom-admin
DASHBOARD_PASSWORD=CHANGEME
STUDIO_DEFAULT_ORGANIZATION=bloom-dev
STUDIO_DEFAULT_PROJECT=bloom-dev-project
STUDIO_PORT=55323
STUDIO_SUPABASE_PUBLIC_URL=http://localhost:8000

# ── GoTrue (Auth) ────────────────────────────────────────────────────────────
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
DISABLE_SIGNUP=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false

# ── Logflare analytics (local dev tokens — not real secrets) ─────────────────
LOGFLARE_PUBLIC_ACCESS_TOKEN=dev-public-token
LOGFLARE_PRIVATE_ACCESS_TOKEN=dev-private-token

# ── Imgproxy ─────────────────────────────────────────────────────────────────
IMGPROXY_URL=http://imgproxy:5001
IMGPROXY_ENABLE_WEBP_DETECTION=true

# ── Caddy reverse proxy (dev = HTTP only) ────────────────────────────────────
CADDY_HTTP_LISTEN_PORT=80
CADDY_HTTPS_LISTEN_PORT=443
CADDY_HTTP_PORT=:80
DOMAIN_MAIN=localhost
DOMAIN_STUDIO=studio.localhost
DOMAIN_MINIO=minio.localhost
DOMAIN_FLASK=api.localhost

# ── Service ports (internal container ports published to host) ───────────────
STORAGE_PORT=5000
META_PORT=8080
LANGCHAIN_PORT=5002
BLOOMMCP_PORT=8811
BLOOM_WEB_PORT=3000

# ── Bloom plots (shared volume between langchain-agent and bloommcp) ──────────
BLOOM_PLOTS_DIR=/app/data/PLOTS_DIR
BLOOM_PLOTS_URL=http://localhost:5002/plots

# ── BloomMCP server ──────────────────────────────────────────────────────────
BLOOMMCP_API_KEY=CHANGEME
BLOOM_MCP_URL=http://bloommcp:8811/mcp

# ── LangChain / LangSmith (tracing disabled in dev) ──────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=bloom-dev
LANGCHAIN_POSTGRES_URL=postgresql://supabase_admin:CHANGEME@db-dev:5432/postgres

# ── Local LLM (disabled in dev — leave empty) ────────────────────────────────
LOCAL_LLM_URL=
LOCAL_LLM_MODEL=

# ── Third-party API keys (USER-SUPPLIED — fill in if you need these features) ─
OPENAI_API_KEY=
LANGCHAIN_API_KEY=
